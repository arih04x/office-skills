# Defense-in-depth: package.json "files" allowlist is the primary control.
# This file documents what must never be published and catches edge cases.

.git/
.github/
.claude/worktrees/
.claude/settings.local.json
.claude/*.local.json

config/office-skills.local.env
config/*.local.env
config/*.secret.env

.env
.env.*
!.env.example

node_modules/
__pycache__/
.pytest_cache/
.venv/
venv/
bin/
obj/

out/
generated/
tmp/
temp/
*.tmp
*.bak

*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_ed25519

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
