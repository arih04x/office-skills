# Copy this file to config/office-skills.local.env and fill in local values.
# config/office-skills.local.env is intentionally ignored by Git.
#
# This single file is the shared local API configuration for image-backed
# PPT, figure, SVG, and motion workflows. Prefer this central config over
# per-skill env files.

# OpenAI-compatible variables:
OPENAI_API_KEY=replace-with-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional local gateway aliases:
ANTHROPIC_API_KEY=replace-with-your-key
ANTHROPIC_API_BASE_URL=https://example.local/v1

# Shared image generation defaults:
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=medium

# PPT-specific overrides:
PPT_IMAGE_MODEL=gpt-image-2
PPT_IMAGE_SIZE=1536x1024
PPT_IMAGE_QUALITY=medium
PPT_IMAGE_INPUT_FIDELITY=high

# Figure/SVG-specific overrides:
FIGURE_IMAGE_MODEL=gpt-image-2
FIGURE_IMAGE_SIZE=1536x1024
FIGURE_IMAGE_QUALITY=medium
FIGURE_IMAGE_INPUT_FIDELITY=high
